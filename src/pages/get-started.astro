---
import BaseLayout from '../layouts/BaseLayout.astro';
import { client } from '../data/client';
const gs = client.getStarted;
---
<BaseLayout title="Get Started · Texas Best Construction">
  <!-- Header + process timeline -->
  <section class="bg-bone text-ink px-8 md:px-12 py-24 md:py-28">
    <div class="max-w-3xl" data-reveal>
      <p class="flex items-center gap-3 font-display font-bold text-sm uppercase tracking-widest text-ink mb-4"><span class="w-8 h-px bg-ink"></span>Start here</p>
      <h1 class="text-4xl md:text-6xl font-display font-extrabold tracking-tight leading-[1.05]">How It Works</h1>
      <p class="mt-6 text-lg md:text-xl text-ink-soft leading-relaxed max-w-2xl">Building with us is clear and collaborative — you're never guessing what comes next. Here's the path from first idea to move-in.</p>
    </div>

    <ol class="mt-16 md:mt-20 max-w-3xl" data-reveal-group>
      {gs.steps.map((step, i) => (
        <li class="flex gap-6 md:gap-10">
          <div class="flex flex-col items-center shrink-0">
            <span class="font-display font-extrabold text-4xl md:text-5xl leading-none tabular-nums">{String(i + 1).padStart(2, '0')}</span>
            {i < gs.steps.length - 1 && <span class="w-px flex-1 bg-ink/15 my-4"></span>}
          </div>
          <div class={`pt-1 ${i < gs.steps.length - 1 ? 'pb-12' : ''}`}>
            <h2 class="text-xl md:text-2xl font-display font-extrabold tracking-tight">{step.title}</h2>
            <p class="mt-2 text-ink-soft text-lg leading-relaxed max-w-xl">{step.description}</p>
            {step.href && (
              <a href={step.href} class="inline-flex items-center gap-1.5 mt-4 font-display font-bold text-sm text-ink hover:gap-2.5 transition-all">
                {step.cta ?? 'Learn more'}
                <span aria-hidden="true">→</span>
              </a>
            )}
          </div>
        </li>
      ))}
    </ol>
  </section>

  <!-- Build options + closing CTA -->
  <section class="bg-dark text-white px-8 md:px-12 py-24 md:py-28">
    <div class="max-w-2xl mb-14" data-reveal>
      <p class="flex items-center gap-3 font-display font-bold text-sm uppercase tracking-widest text-white mb-4"><span class="w-8 h-px bg-white"></span>Two ways to build</p>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-display font-extrabold tracking-tight leading-tight">Shell or turnkey — your call.</h2>
    </div>

    <div class="grid md:grid-cols-2 gap-6 max-w-4xl" data-reveal-group>
      {gs.buildOptions.map((opt) => (
        <div class="bg-white/5 border border-white/10 rounded-sm p-8 flex flex-col">
          <h3 class="font-display font-extrabold text-2xl">{opt.name}</h3>
          <p class="text-white/70 mt-3 leading-relaxed flex-1">{opt.description}</p>
          <p class="mt-6 pt-5 border-t border-white/10 font-display font-bold text-sm uppercase tracking-wide text-white/50">{opt.radius}</p>
        </div>
      ))}
    </div>

    <div class="mt-14 flex flex-col sm:flex-row sm:items-center gap-4 sm:gap-6 max-w-4xl" data-reveal>
      <p class="text-white/70 text-lg">Ready to start? Get your free, no-pressure quote.</p>
      <div class="flex flex-wrap gap-3">
        <a href="/quote" class="font-display font-bold text-sm bg-white hover:bg-stone text-ink px-5 py-3 rounded-sm transition">Get a Quote</a>
        <a href="tel:4695528205" class="font-display font-bold text-sm border border-white/30 hover:bg-white/10 text-white px-5 py-3 rounded-sm transition">Call {client.phone}</a>
      </div>
    </div>
  </section>
</BaseLayout>
