---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<BaseLayout title="Barndo Buzz · Texas Best Construction">
  <section class="bg-bone text-ink px-8 md:px-12 py-24 md:py-28">
    <div class="max-w-3xl" data-reveal>
      <p class="flex items-center gap-3 font-display font-bold text-sm uppercase tracking-widest text-ink mb-4"><span class="w-8 h-px bg-ink"></span>Barndo Buzz</p>
      <h1 class="text-4xl md:text-6xl font-display font-extrabold tracking-tight leading-[1.05]">Barndo Buzz</h1>
      <p class="mt-6 text-lg md:text-xl text-ink-soft leading-relaxed max-w-2xl">News, build updates, and barndominium know-how from Josh &amp; Brandy Helm.</p>
    </div>

    {posts.length === 0 && (
      <p class="mt-16 text-ink-soft italic" data-reveal>No posts yet — check back soon.</p>
    )}

    <div class="mt-16 grid sm:grid-cols-2 lg:grid-cols-3 gap-8" data-reveal-group>
      {posts.map((post) => (
        <a href={`/buzz/${post.id}`} class="group block">
          <div class="aspect-[4/3] bg-stone rounded-sm overflow-hidden mb-4">
            {post.data.image
              ? <img src={post.data.image} alt={post.data.title} class="w-full h-full object-cover grayscale transition-transform duration-500 group-hover:scale-105" />
              : <div class="w-full h-full flex items-center justify-center text-ink-soft text-sm italic transition-transform duration-500 group-hover:scale-105">post image</div>}
          </div>
          <p class="font-display font-bold text-xs uppercase tracking-wide text-ink-soft">{fmt(post.data.date)}</p>
          <h2 class="text-xl font-display font-extrabold mt-1.5 leading-snug group-hover:underline underline-offset-4 decoration-1 transition">{post.data.title}</h2>
          <p class="text-ink-soft mt-2 leading-relaxed">{post.data.excerpt}</p>
          <span class="inline-flex items-center gap-1.5 mt-3 font-display font-bold text-sm text-ink group-hover:gap-2.5 transition-all">Read more <span aria-hidden="true">→</span></span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
