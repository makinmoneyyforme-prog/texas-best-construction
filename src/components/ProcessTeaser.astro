---
// ProcessTeaser.astro — the homepage "How it works" funnel step. Condenses the
// Get Started page (process steps + build options) inline. Reuses
// client.getStarted (single source); the full page lives at /get-started.
import { client } from '../data/client';
const steps = client.getStarted.steps;
const buildOptions = client.getStarted.buildOptions;
---
<section class="bg-bone text-ink px-8 md:px-12 py-20 md:py-24" data-reveal>
  <div class="max-w-2xl mb-12">
    <p class="flex items-center gap-3 font-display font-bold text-sm uppercase tracking-widest text-ink mb-4"><span class="w-8 h-px bg-ink"></span>How it works</p>
    <h2 class="text-3xl md:text-4xl lg:text-5xl font-display font-extrabold tracking-tight leading-tight">A clear path from first idea to move-in.</h2>
    <p class="mt-4 text-ink-soft text-lg leading-relaxed">No guessing what comes next — here's the process, start to finish.</p>
  </div>

  <ol class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-x-6 gap-y-8" data-reveal-group>
    {steps.map((step, i) => (
      <li class="border-t border-ink/15 pt-4">
        <div class="font-display font-extrabold text-2xl tabular-nums text-ink">{String(i + 1).padStart(2, '0')}</div>
        <div class="mt-2 font-display font-bold text-sm leading-snug">{step.title}</div>
      </li>
    ))}
  </ol>

  <!-- Build options -->
  <div class="mt-16 pt-12 border-t border-ink/10">
    <h3 class="font-display font-extrabold text-2xl md:text-3xl tracking-tight">Two ways to build</h3>
    <div class="grid md:grid-cols-2 gap-6 mt-8 max-w-4xl" data-reveal-group>
      {buildOptions.map((opt) => (
        <div class="bg-white border border-ink/10 rounded-sm p-7 flex flex-col">
          <h4 class="font-display font-extrabold text-xl">{opt.name}</h4>
          <p class="text-ink-soft mt-3 leading-relaxed flex-1">{opt.description}</p>
          <p class="mt-6 pt-5 border-t border-ink/10 font-display font-bold text-sm uppercase tracking-wide text-ink-soft">{opt.radius}</p>
        </div>
      ))}
    </div>
  </div>

  <a href="/get-started" class="inline-flex items-center gap-1.5 mt-12 font-display font-bold text-sm border border-ink hover:bg-ink hover:text-white text-ink px-5 py-3 rounded-sm transition">
    See the full process
    <span aria-hidden="true">→</span>
  </a>
</section>
