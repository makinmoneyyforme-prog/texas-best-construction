---
// About.astro — who-we-are + stats band. Pure presentation; content comes from client.ts.
import { client } from '../data/client';
const a = client.about;
---
<section id="about" class="bg-dark text-white px-8 md:px-12 py-24 md:py-28">
  <div class="grid md:grid-cols-2 gap-10 md:gap-16 items-center" data-reveal-group>
    <div class="aspect-[4/5] bg-dark-2 ring-1 ring-inset ring-white/10 rounded-sm flex items-center justify-center text-white/30 text-sm italic" data-reveal-img>owner / team photo</div>
    <div>
      <p class="flex items-center gap-3 font-display font-bold text-sm uppercase tracking-widest text-white mb-4"><span class="w-8 h-px bg-white"></span>{a.eyebrow}</p>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-display font-extrabold tracking-tight leading-tight mb-6">{a.headline}</h2>
      {a.paragraphs.map((p, i) => (
        <p class={`text-white/80 text-lg leading-relaxed${i < a.paragraphs.length - 1 ? ' mb-4' : ''}`}>{p}</p>
      ))}
    </div>
  </div>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mt-16 pt-12 border-t border-white/10" data-reveal-group>
    {a.stats.map((s) => (
      <div>
        <div class="font-display font-extrabold text-4xl md:text-5xl" data-countup>{s.num}</div>
        <div class="text-white/70 text-sm mt-2 uppercase tracking-wide">{s.label}</div>
      </div>
    ))}
  </div>
</section>
