---
// ServiceAreaBand.astro — slim self-qualify band (under hero + on /quote).
// Pure presentation; content comes from client.ts (single source).
import { client } from '../data/client';
const sa = client.serviceArea;
---
<section class="bg-bone text-ink border-b border-ink/10 px-8 md:px-12 py-4" data-reveal>
  <p class="flex flex-wrap items-center justify-center gap-x-4 gap-y-1.5 text-center font-display font-bold text-xs sm:text-sm uppercase tracking-wide">
    <span class="text-ink">{sa.turnkey}</span>
    <span class="w-1 h-1 rounded-full bg-ink-soft/40" aria-hidden="true"></span>
    <span class="text-ink">{sa.shell}</span>
    <span class="w-1 h-1 rounded-full bg-ink-soft/40" aria-hidden="true"></span>
    <span class="text-ink-soft">{sa.area}</span>
  </p>
</section>
