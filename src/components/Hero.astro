---
// Hero.astro — the kit's hero section. Pure presentation; content comes from client.ts.
import { client } from '../data/client';
const h = client.hero;
---
<section class="grid md:grid-cols-2 min-h-[34rem]">
  <div class="bg-dark text-white flex flex-col justify-center px-8 py-16 md:px-12">
    <p class="flex items-center gap-3 font-display text-white font-bold text-xs tracking-[0.18em] uppercase"><span class="w-8 h-px bg-white"></span>{h.eyebrow}</p>
    <h1 class="font-display text-white text-4xl md:text-5xl lg:text-6xl mt-4 max-w-[14ch]">{h.headlineLead} <span>{h.headlineAccent}</span> {h.headlineTrail}</h1>
    <p class="text-white/80 text-lg mt-4 max-w-[42ch] leading-snug">{h.subhead}</p>
    <div class="flex flex-wrap gap-3 mt-8">
      <a href="#contact" class="font-display font-bold text-sm bg-white hover:bg-stone text-ink px-5 py-3 rounded-sm transition">{h.primaryCta}</a>
      <a href="tel:" class="font-display font-bold text-sm border border-white/30 hover:bg-white/10 text-white px-5 py-3 rounded-sm transition">Call {client.phone}</a>
    </div>
    <div class="flex flex-wrap gap-6 mt-10 pt-5 border-t border-white/15 text-xs uppercase tracking-wide text-white/70">
      {h.trust.map((t) => (
        <span><b class="font-display text-white">{t.strong}</b> {t.rest}</span>
      ))}
    </div>
  </div>
  <div class="relative min-h-[18rem] flex items-end" style="background:linear-gradient(135deg,#181819,#0C0C0D);">
    <div class="absolute inset-0 opacity-40" style="background-image:linear-gradient(rgba(255,255,255,.08) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.08) 1px,transparent 1px);background-size:46px 46px;"></div>
    <span class="relative m-4 px-3 py-2 bg-black/40 border border-white/15 rounded-sm text-xs text-white/60 italic">real project photo drops in here</span>
  </div>
</section>
