---
// Header.astro — global site nav. Pure presentation; content comes from client.ts.
// Renders once via BaseLayout, so every page gets the same header.
import { client } from '../data/client';
const n = client.nav;

// Active-page indicator. Normalise away a trailing slash so "/projects/" and
// "/projects" both match.
const path = Astro.url.pathname.replace(/\/+$/, '') || '/';
const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href + '/');
---
<header class="sticky top-0 z-50 bg-dark/95 backdrop-blur border-b border-white/10">
  <nav class="px-8 md:px-12 h-20 flex items-center justify-between gap-6">
    <a href="/" class="font-display font-extrabold text-xl tracking-tight text-white uppercase shrink-0">{client.name}<span class="text-white">.</span></a>

    <!-- Desktop primary nav -->
    <div class="hidden lg:flex items-center gap-8 text-sm font-medium text-white/70">
      {n.primary.map((l) => (
        <a
          href={l.href}
          target={l.external ? '_blank' : undefined}
          rel={l.external ? 'noopener noreferrer' : undefined}
          aria-current={isActive(l.href) ? 'page' : undefined}
          class:list={[
            'relative inline-flex items-center gap-1 transition hover:text-white',
            isActive(l.href)
              ? 'text-white after:absolute after:-bottom-1.5 after:left-0 after:h-px after:w-full after:bg-white'
              : 'link-underline',
          ]}
        >{l.label}{l.external && <span class="text-white/40 text-xs" aria-hidden="true">↗</span>}</a>
      ))}

      <!-- Resources dropdown (opens on hover + keyboard focus) -->
      <div class="relative group">
        <button
          type="button"
          aria-haspopup="true"
          class="flex items-center gap-1.5 transition hover:text-white group-focus-within:text-white"
        >
          {n.resourcesLabel}
          <svg class="w-3 h-3 transition-transform group-hover:rotate-180 group-focus-within:rotate-180" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2.5 4.5 6 8l3.5-3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div class="absolute right-0 top-full pt-3 w-60 invisible opacity-0 translate-y-1 transition-all duration-200 group-hover:visible group-hover:opacity-100 group-hover:translate-y-0 group-focus-within:visible group-focus-within:opacity-100 group-focus-within:translate-y-0">
          <div class="bg-dark-2 border border-white/10 rounded-sm py-2 shadow-xl shadow-black/40">
            {n.resources.map((r) => (
              <a
                href={r.href}
                target={r.external ? '_blank' : undefined}
                rel={r.external ? 'noopener noreferrer' : undefined}
                class="flex items-center justify-between gap-3 px-4 py-2.5 text-white/70 hover:text-white hover:bg-white/5 transition"
              >
                <span>{r.label}</span>
                {r.external && <span class="text-white/40 text-xs" aria-hidden="true">↗</span>}
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Desktop right: phone + CTA -->
    <div class="hidden lg:flex items-center gap-5 shrink-0">
      <a href={n.phone.href} class="font-display font-bold text-sm text-white whitespace-nowrap">{n.phone.label}</a>
      <a href={n.cta.href} class="font-display font-bold text-sm bg-white hover:bg-stone text-ink px-4 py-2.5 rounded-sm transition whitespace-nowrap">{n.cta.label}</a>
    </div>

    <!-- Mobile hamburger -->
    <button
      id="nav-open"
      type="button"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      class="lg:hidden flex flex-col items-center justify-center gap-1.5 w-10 h-10 -mr-2 text-white"
    >
      <span class="block w-6 h-px bg-white"></span>
      <span class="block w-6 h-px bg-white"></span>
      <span class="block w-6 h-px bg-white"></span>
    </button>
  </nav>

  <!-- Mobile slide-in menu -->
  <div id="mobile-menu" class="fixed inset-0 z-[60] lg:hidden invisible" aria-hidden="true">
    <div id="nav-backdrop" class="absolute inset-0 bg-black/60 opacity-0 transition-opacity duration-300"></div>
    <div
      id="nav-panel"
      class="absolute inset-y-0 right-0 w-full max-w-sm bg-dark text-white flex flex-col translate-x-full transition-transform duration-300 ease-out"
    >
      <div class="flex items-center justify-between h-20 px-8 border-b border-white/10 shrink-0">
        <span class="font-display font-extrabold text-xl tracking-tight text-white uppercase">{client.name}<span class="text-white">.</span></span>
        <button id="nav-close" type="button" aria-label="Close menu" class="flex items-center justify-center w-10 h-10 -mr-2 text-white/70 hover:text-white transition">
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </button>
      </div>

      <div class="flex-1 overflow-y-auto px-8 py-8">
        <nav class="flex flex-col">
          {n.primary.map((l) => (
            <a
              href={l.href}
              data-nav-link
              target={l.external ? '_blank' : undefined}
              rel={l.external ? 'noopener noreferrer' : undefined}
              aria-current={isActive(l.href) ? 'page' : undefined}
              class:list={[
                'flex items-center gap-2 font-display font-bold text-2xl py-2.5 transition',
                isActive(l.href) ? 'text-white' : 'text-white/70 hover:text-white',
              ]}
            >{l.label}{l.external && <span class="text-white/40 text-base" aria-hidden="true">↗</span>}</a>
          ))}
        </nav>

        <p class="font-display font-bold text-xs uppercase tracking-widest text-white/40 mt-10 mb-3">{n.resourcesLabel}</p>
        <nav class="flex flex-col">
          {n.resources.map((r) => (
            <a
              href={r.href}
              data-nav-link
              target={r.external ? '_blank' : undefined}
              rel={r.external ? 'noopener noreferrer' : undefined}
              class="flex items-center gap-2 text-white/70 hover:text-white py-2 transition"
            >
              <span>{r.label}</span>
              {r.external && <span class="text-white/40 text-xs" aria-hidden="true">↗</span>}
            </a>
          ))}
        </nav>
      </div>

      <div class="px-8 py-6 border-t border-white/10 shrink-0 space-y-3">
        <a href={n.phone.href} data-nav-link class="block font-display font-bold text-lg text-white text-center">{n.phone.label}</a>
        <a href={n.cta.href} data-nav-link class="block font-display font-bold text-sm bg-white hover:bg-stone text-ink px-4 py-3.5 rounded-sm transition text-center">{n.cta.label}</a>
      </div>
    </div>
  </div>
</header>

<script>
  const menu = document.getElementById('mobile-menu');
  const panel = document.getElementById('nav-panel');
  const backdrop = document.getElementById('nav-backdrop');
  const openBtn = document.getElementById('nav-open');
  const closeBtn = document.getElementById('nav-close');

  if (menu && panel && backdrop && openBtn && closeBtn) {
    let isOpen = false;

    const open = () => {
      isOpen = true;
      menu.classList.remove('invisible');
      menu.setAttribute('aria-hidden', 'false');
      openBtn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
      window.lenis?.stop();
      // Next frame so the transition runs from the hidden state.
      requestAnimationFrame(() => {
        backdrop.classList.replace('opacity-0', 'opacity-100');
        panel.classList.replace('translate-x-full', 'translate-x-0');
      });
    };

    const close = () => {
      if (!isOpen) return;
      isOpen = false;
      backdrop.classList.replace('opacity-100', 'opacity-0');
      panel.classList.replace('translate-x-0', 'translate-x-full');
      openBtn.setAttribute('aria-expanded', 'false');
      menu.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      window.lenis?.start();
      // Re-hide after the slide-out completes so it can't catch clicks.
      window.setTimeout(() => {
        if (!isOpen) menu.classList.add('invisible');
      }, 300);
      openBtn.focus();
    };

    openBtn.addEventListener('click', open);
    closeBtn.addEventListener('click', close);
    backdrop.addEventListener('click', close);
    menu.querySelectorAll('[data-nav-link]').forEach((link) => link.addEventListener('click', close));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) close();
    });
  }
</script>
