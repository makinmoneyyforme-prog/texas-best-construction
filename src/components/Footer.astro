---
// Footer.astro — site footer. Pure presentation; content comes from client.ts.
import { client } from '../data/client';
const f = client.footer;
const contact = [
  { label: client.phone, href: "tel:" },
  { label: client.email, href: "mailto:" },
];
---
<footer class="bg-dark text-white px-8 md:px-12 pt-20 pb-10">
  <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8">
    <div class="lg:pr-8">
      <a href="/" class="font-display font-extrabold text-2xl tracking-tight text-white uppercase">{client.name}<span class="text-white">.</span></a>
      <p class="text-white/70 leading-relaxed mt-4 max-w-[32ch]">{f.tagline}</p>

      <div class="mt-7">
        <h3 class="font-display font-bold text-xs uppercase tracking-widest text-white/50 mb-3">For clients</h3>
        <ul class="flex flex-wrap gap-x-5 gap-y-2">
          {f.clientLinks.map((l) => (
            <li>
              <a
                href={l.href}
                target={l.external ? '_blank' : undefined}
                rel={l.external ? 'noopener noreferrer' : undefined}
                class="inline-flex items-center gap-1 text-white/70 hover:text-white transition link-underline"
              >{l.label}{l.external && <span class="text-white/40 text-xs" aria-hidden="true">↗</span>}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div>
      <h3 class="font-display font-bold text-sm uppercase tracking-widest text-white mb-5">Quick links</h3>
      <ul class="space-y-3">
        {f.quickLinks.map((l) => (
          <li><a href={l.href} class="text-white/70 hover:text-white transition link-underline">{l.label}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <h3 class="font-display font-bold text-sm uppercase tracking-widest text-white mb-5">Service area</h3>
      <ul class="space-y-3">
        {f.towns.map((t) => <li class="text-white/70">{t}</li>)}
      </ul>
    </div>

    <div>
      <h3 class="font-display font-bold text-sm uppercase tracking-widest text-white mb-5">Contact</h3>
      <ul class="space-y-3">
        {contact.map((c) => (
          <li><a href={c.href} class="text-white/70 hover:text-white transition link-underline">{c.label}</a></li>
        ))}
      </ul>
    </div>
  </div>

  <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mt-16 pt-8 border-t border-white/10">
    <p class="text-white/60 text-sm">{f.licenseNumber ? `Licensed & Insured · License #${f.licenseNumber}` : "Insured"}</p>
    <div class="flex items-center gap-6 text-sm font-display font-bold uppercase tracking-wide">
      {f.socials.map((s) => (
        <a href={s.href} class="text-white/70 hover:text-white transition link-underline">{s.label}</a>
      ))}
    </div>
    <p class="text-white/60 text-sm">© {f.copyrightYear} {client.legalName}. All rights reserved.</p>
  </div>
</footer>
